rorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},{"filePath":"55","messages":"56","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},{"filePath":"57","messages":"58","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},{"filePath":"59","messages":"60","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"61","messages":"62","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},{"filePath":"63","messages":"64","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"65","usedDeprecatedRules":"36"},{"filePath":"66","messages":"67","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"68","messages":"69","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},{"filePath":"70","messages":"71","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/index.js",[],["72","73"],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/App.js",["74","75","76"],"import logo from './logo.svg';\nimport {useContext} from \"react\"\nimport {Switch, Route, Redirect} from \"react-router-dom\"\nimport './App.css';\nimport Auth from \"./components/Auth.js\"\nimport Profile from \"./components/Profile.js\"\nimport Public from \"./components/Public.js\"\nimport AuthForm from \"./components/AuthForm.js\"\nimport NavBar from \"./components/NavBar.js\"\nimport {UserContext} from \"./context/UserContext.js\"\nfunction App() {\n  const { token, logout } = useContext(UserContext)\n  return (\n    <div className=\"App\">\n      <Switch>\n        <Route exact path=\"/\">\n          {token?\n            <Redirect to=\"/profile\"/>\n            :\n            <>\n            <Auth />\n            </>\n          }\n        </Route>\n\n        <Route exact path=\"/profile\">\n            <NavBar />\n            <Profile />\n        </Route>\n\n        <Route exact path=\"/public\">\n            <NavBar />\n            <Public />\n        </Route>\n      </Switch>\n\n      \n    </div>\n  );\n}\n\nexport default App;\n","/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/reportWebVitals.js",[],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/Auth.js",[],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/Public.js",["77"],"import React, {useState, useEffect} from \"react\"\nimport User from \"./User.js\"\nconst axios = require(\"axios\")\n\nfunction Public() {\n    const userAxios = axios.create()\n\n    userAxios.interceptors.request.use(config => {\n        const token = localStorage.getItem(\"token\")\n        config.headers.Authorization = `Bearer ${token}`\n        return config\n    })\n\n    const [users, setUsers] = useState([])\n\n\n    \n    useEffect(()=>{userAxios.get(\"/api/users\")\n        .then(res => setUsers(res.data))\n        .catch(err => console.log(err.response.data.errMsg))\n        },\n        []\n    )\n    \n    return (\n        <div className=\"publicIssuesHolder\">\n            {users.map(user => <User {...user}/>)}\n        </div>\n    )\n\n}\n\nexport default Public","/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/Profile.js",["78"],"import React, {useContext, useEffect} from \"react\"\nimport {Link} from \"react-router-dom\"\nimport { UserContext } from \"../context/UserContext.js\"\nimport IssueForm from \"./IssueForm.js\"\nimport IssueList from \"./IssueList.js\"\nfunction Profile() {\n    const {\n        user: {\n            username\n        },\n        getUserIssues,\n        addIssue,\n        issues,\n        logout\n    } = useContext(UserContext)\n\n\n\n    useEffect(getUserIssues, [])\n    return (\n        <>\n        <h1>Welcome {username}!</h1>\n        <h2>Scroll all the way down to log out.</h2>\n        <h3>Add an Issue</h3>\n            <IssueForm addIssue={addIssue} />\n        <h3>Your issues</h3>\n            <IssueList issues={issues}/>\n            <button onClick={logout}>\n                <Link to=\"/\">\n                Log Out\n                </Link>\n            </button>\n        </>\n    )\n}\n\n\nexport default Profile","/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/AuthForm.js",["79"],"import React, {useState} from \"react\"\n\nfunction AuthForm(props) {\n    const {\n        handleChange,\n        handleSubmit, \n        inputs: {\n            username,\n            password\n        },\n        btnText\n    } = props\n    return (\n        <form onSubmit={handleSubmit}>\n        <input \n          type=\"text\" \n          name=\"username\" \n          value={username} \n          onChange={handleChange} \n          placeholder=\"Username\"/>\n        <input \n          type=\"text\" \n          name=\"password\" \n          value={password} \n          onChange={handleChange} \n          placeholder=\"Password\"/>\n        <button>{btnText}</button>\n      </form>\n    )\n}\n\nexport default AuthForm","/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/context/UserContext.js",[],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/IssueList.js",[],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/IssueForm.js",[],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/Issue.js",["80","81"],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/NavBar.js",[],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/User.js",["82"],"import React, {useState, useEffect} from \"react\"\nimport PublicIssue from \"./PublicIssue.js\"\nimport axios from \"axios\"\n\nfunction User(props) {\n    const {username, _id} = props\n    const [issues, setIssues] = useState([])\n    const userAxios = axios.create()\n\n    userAxios.interceptors.request.use(config => {\n        const token = localStorage.getItem(\"token\")\n        config.headers.Authorization = `Bearer ${token}`\n        return config\n    })\n    useEffect(() => {\n        userAxios.get(`/api/issue/user/${_id}`) //changedthis\n        .then(res => setIssues(res.data))\n        .catch(err => console.log(err.response.data.errMsg))\n    },\n    []\n    )\n    return (\n        <div className=\"userCard\">\n            <h1>{username}'s Issues</h1>\n            {issues.map(issue => <PublicIssue {...issue}/>)}\n        </div>\n    )\n}\n\nexport default React.memo(User)","/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/PublicIssue.js",["83","84","85"],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/IssueEditForm.js",[],"/Users/joshuabenbaba/Documents/V-SCHOOL/Projects/module-6/rock-the-vote/client/src/components/Comment.js",[],{"ruleId":"86","replacedBy":"87"},{"ruleId":"88","replacedBy":"89"},{"ruleId":"90","severity":1,"message":"91","line":1,"column":8,"nodeType":"92","messageId":"93","endLine":1,"endColumn":12},{"ruleId":"90","severity":1,"message":"94","line":8,"column":8,"nodeType":"92","messageId":"93","endLine":8,"endColumn":16},{"ruleId":"90","severity":1,"message":"95","line":12,"column":18,"nodeType":"92","messageId":"93","endLine":12,"endColumn":24},{"ruleId":"96","severity":1,"message":"97","line":22,"column":9,"nodeType":"98","endLine":22,"endColumn":11,"suggestions":"99"},{"ruleId":"96","severity":1,"message":"100","line":19,"column":5,"nod